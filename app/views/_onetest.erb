
<div class="wide-container">
  <div class="form-card">

<details id="exec-details-<%= test.identifier %>"
         data-openapi-url="<%= test.openapi %>"
         data-test-id="<%= test.identifier %>"
         data-endpoint="<%= test.endpoint %>"
         class="execute-details mb-3">
      <summary  class="submit-link"><%= test.title %></summary>


      <table class="table" style="width: 100%;">
        <tr>      
          <td colspan="2">
            <div class="loading-state mt-3" style="display: none;">
              <p>Loading API specification...</p>
              <!-- optional spinner -->
              <div class="spinner-border text-primary" role="status"></div>
            </div>
          </td>
        </tr>
        <tr>
          <td colspan="2">
            <div class="form-container mt-3" style="display: none;">
              <!-- The appropriate form will be injected here via JS -->
            </div>
                      <!-- Default/fallback form (shown if JS disabled or fetch fails) -->
            <noscript>
            <p class="text-muted">JavaScript is disabled — using default GUID submission.</p>
            <form action="/champion/test-execution-proxy" method="post">
              <input type="hidden" name="endpoint" value="<%= test.endpoint %>">
              <label for="resource_identifier_<%= test.identifier %>">Resource Identifier</label>
              <input type="text" name="resource_identifier" id="resource_identifier_<%= test.identifier %>" 
                    placeholder="e.g., https://example.org/dataset">
              <input type="submit" value="Test it">
            </form>
            </noscript>

          </td>
        </tr>
        <tr>

          <th>Error messages will appear here:</th>
          <td>
            <div class="error-state mt-3 text-danger" style="display: none;">
              <!-- Error message injected here -->
            </div>
          </td>
        </tr>
          
        </tr>
      </table>
    </details>
    <p class="mb-3"><%= test.description %></p>
    <p class="mb-3">
      <a href="<%= test.openapi %>" class="submit-link" target="_blank">API Definition</a>
    </p>

    <details>
      <summary>Additional Details</summary>
      <table class="table" style="width: 100%;">
        <!-- identifier: solution[:identifier].to_s,
          title: solution[:title].to_s,
          description: solution[:description].to_s,
          endpoint: solution[:endpoint].to_s,
          openapi: solution[:openapi].to_s,
          dimension: solution[:dimension].to_s,
          objects: solution[:objects].to_s,
          domain: solution[:domain].to_s,
          benchmark_or_metric: solution[:benchmark_or_metric].to_s
-->
        <tr>
          <th class="bg-gray-200 text-left">Test ID (for Benchmark Algorithm Spreadsheet)</th>
          <td><a href="<%= test.identifier %>" target="_blank"><%= test.identifier %></a></td>
        </tr>
        <tr>
          <th class="bg-gray-200 text-left">Execution Endpoint</th>
          <td><a href="<%= test.endpoint %>" target="_blank"><%= test.endpoint %></a></td>
        </tr>
        <tr>
          <th class="bg-gray-200 text-left">Applicable to Digital Object Type</th>
          <td>
            <% if test.objects&.any? %>
              <%= test.objects.map { |item|
                url = item.to_s
                escaped_url   = url.gsub('&', '&amp;').gsub('"', '&quot;').gsub('<', '&lt;').gsub('>', '&gt;')
                escaped_label = url.gsub('&', '&amp;').gsub('<', '&lt;').gsub('>', '&gt;')
                "<a href=\"#{escaped_url}\" target=\"_blank\" rel=\"noopener noreferrer\">#{escaped_label}</a>"
              }.join(', ') %>
            <% else %>
              —
            <% end %>
          </td>
        </tr>

        <tr>
          <th class="bg-gray-200 text-left">Applicable to Scholarly Domain</th>
          <td>
            <% if test.domain&.any? %>
              <%= test.domain.map { |item|
                url = item.to_s
                escaped_url   = url.gsub('&', '&amp;').gsub('"', '&quot;').gsub('<', '&lt;').gsub('>', '&gt;')
                escaped_label = url.gsub('&', '&amp;').gsub('<', '&lt;').gsub('>', '&gt;')
                "<a href=\"#{escaped_url}\" target=\"_blank\" rel=\"noopener noreferrer\">#{escaped_label}</a>"
              }.join(', ') %>
            <% else %>
              —
            <% end %>
          </td>
        </tr>        
        <tr>
          <th class="bg-gray-200 text-left">Implementation of Metric</th>
          <td><a href="<%= test.benchmark_or_metric&.to_s %>" target="_blank"><%= test.benchmark_or_metric&.to_s %></a></td>
        </tr>
      </table>
    </details>


  </div>
</div>