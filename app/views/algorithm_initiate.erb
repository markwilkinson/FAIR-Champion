<!-- views/algorithm_input.erb -->
<div class="container">
  <header class="header">
    <div class="code-block">
      <p>Generic CURL command:</p>
      <pre>
curl -X POST -H "Accept: application/json" -H "Content-type: application/json" 
      -d '{"calculation_uri":  "https://sheets.google.com....",
           "guid":  "https://my.favorite.digital/object"}' 
           https://w3id.org/FAIR-Champion/assess/algorithm
      </pre>
or, if you know the ID of the algorithm...  (note that IDs include the /d/ or /u/ path from Google Sheets!)
      <pre>
curl -X POST -H "Accept: application/json" -H "Content-type: application/json" 
      -d  '{"guid":  "https://my.favorite.digital/object"}'
           https://w3id.org/FAIR-Champion/assess/algorithm/d/AJURG8ewy45hIUDH38rhU

           or

curl -X POST -H "Accept: application/json" -H "Content-type: application/json" 
      -d  @resultsetfile.json   # THIS MUST BE JSON-LD!!!!!!
           https://w3id.org/FAIR-Champion/assess/algorithm/d/AJURG8ewy45hIUDH38rhU
      </pre>
    </div>
</header>

</div>
<div class="container">
  <div class="form-card">

    <form action="/champion/assess/algorithm" method="post" class="">
      <div class="form-group mb-3">
        <label for="calculation_uri" class="block text-sm font-medium mb-1">Algorithm Configuration Google Spreadsheet URL: (<a href="https://docs.google.com/spreadsheets/d/16s2klErdtZck2b6i2Zp_PjrgpBBnnrBKaAvTwrnMB4w/edit?gid=0#gid=0">Example</a>)</label><br/>
        <select id="calculation_uri_select" size="6"
                onchange="document.getElementById('calculation_uri').value = this.value"
                class="form-control w-100 algorithm-select">
          <% @list.map { |item| item.slice(:title, :description, :calculation_uri) }.uniq.sort_by { |item| item[:title] }.each do |item| %>
            <optgroup label="<%= item[:title] %>">
              <option value="<%= item[:calculation_uri] %>"><%= item[:description] %></option>
            </optgroup>
          <% end %>
        </select>
        <input type="text" id="calculation_uri" name="calculation_uri" class="form-control w-100 mt-2"
               placeholder="Or paste a spreadsheet URI directly" autocomplete="off" required>
        <style>
          #calculation_uri,
          .algorithm-select {
            min-width: 900px;
            width: 100%;
          }
          .algorithm-select {
            height: auto;
            overflow-y: auto;
            border: 1px solid #ced4da;
            border-radius: 4px;
            background: #fff;
          }
          .algorithm-select optgroup {
            font-weight: bold;
            color: #222;
            font-size: 0.95em;
            padding-top: 4px;
          }
          .algorithm-select option {
            font-weight: normal;
            color: #555;
            font-size: 0.88em;
            padding-left: 1.5em;
            white-space: normal;
          }
          .algorithm-select option:hover,
          .algorithm-select option:checked {
            background: #0d6efd;
            color: #fff;
          }
          .mt-2 { margin-top: 0.5rem; }
        </style>
      </div>
      <div><h2 class="header">You may now apply the selected algorithm to a new Digital Object, or an existing Test Result Set</h2></div>
      <div class="form-group mb-3">
        <label for="guid" class="block text-sm font-medium mb-1">GUID:</label>
        <input type="text" id="guid" name="guid" class="form-control w-full" placeholder="e.g., https://w3id.org/duchenne-fdp">
      </div>
      <div><h2 class="header">OR</h2></div>
      <div class="form-group mb-3">
        <label for="assessment_file" class="block text-sm font-medium mb-1">Apply Algorith to Existing Test Result Set (JSON-LD):</label>
        <input type="file" id="assessment_file" name="file" class="form-control w-full" accept="application/json,.jsonld">
      </div>
      <div class="text-center">
        <button type="submit" class="submit-link btn btn-primary">Run Benchmark Quality Assessment</button>
      </div>
    </form>  
  </div>
</div>