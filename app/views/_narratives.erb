<h2 class="mb-3">Conclusions:</h2>
<table class="table"><tr><th>Condition</th><th>Discussion</th><th>Guidance</th></tr>
  <% warn "GUIDANCES: " + guidances.inspect %>
  <% narratives.each_with_index do |narrative, index| %>
    <% guidance = guidances[index] %>
    <tr><td class="p-2"><%= index + 1 %></td>
    <td class="p-2"><%= narrative %></td>
    <% if guidance %> <!-- guidance might not exist if all tests passed -->
      <td class="p-2">
        <% guidance.each do |g| %>
          <% next unless g and g.is_a? Array %>
          <%= g[1] %>. <a href="<%= g[0] %>">More Information</a><br/><br>
        <% end %>
      </td>
    <% else %>
      <td class="p-2"></td>
    <% end %>
    </tr>
  <% end %>
</table>