<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title>FAIR Champion: Tests</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <link rel="stylesheet" href="/champion/css/styles.css"/>
  <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
  <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>

<body id="default">

<!-- This might not be necessary anymore -->
<script src="https://cdn.jsdelivr.net/npm/js-yaml@4.1.0/dist/js-yaml.min.js"></script>

<!-- This is to create the execute service form, for either GUID entry or file upload -->
<script>  
// Run once DOM is ready
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('details.execute-details').forEach(details => {
    details.addEventListener('toggle', async function onToggle() {
      // Only run once — when opening
      if (!this.open || this.dataset.loaded) return;

      this.dataset.loaded = 'true'; // prevent re-fetch on re-open

      const openapiUrl   = this.dataset.openapiUrl;
      const testId       = this.dataset.testId;
      const endpoint     = this.dataset.endpoint;

      const loadingEl    = this.querySelector('.loading-state');
      const formContainer = this.querySelector('.form-container');
      const errorEl      = this.querySelector('.error-state');

      loadingEl.style.display = 'block';
      formContainer.style.display = 'none';
      errorEl.style.display = 'none';

      try {
        const response = await fetch(openapiUrl, {
          cache: 'no-cache',           // important — frequent changes
          headers: { Accept: 'application/yaml, application/json' }
        });

        if (!response.ok) throw new Error(`HTTP ${response.status}`);

        const text = await response.text();
        let spec;

        try {
          spec = jsyaml.load(text);           // YAML first
        } catch (yamlErr) {
          try {
            spec = JSON.parse(text);          // fallback to JSON
          } catch {
            throw new Error('Invalid OpenAPI format (not valid YAML/JSON)');
          }
        }

        // === Minimal detection logic (same heuristics as before) ===
        let mode = 'guid';          // default
        let isAsync = false;
        let uploadField = 'file';

        // Look for relevant POST path (heuristic)
        const paths = spec.paths || {};
        let postOp = null;
        for (const [pathKey, item] of Object.entries(paths)) {
          if (pathKey.match(/assess|evaluate|test|run|execute|submit|algorithm|metric/i) && item.post) {
            postOp = item.post;
            break;
          }
        }

        if (postOp) {
          const responses = postOp.responses || {};

          // Async check
          const has202 = !!responses['202'] || Object.keys(responses).some(k => Number(k) === 202);
          if (has202) {
            const resp202 = responses['202'] || Object.values(responses).find(r => r?.['x-status']?.includes('202')); // fallback
            if (resp202?.headers?.Location || resp202?.headers?.['location']) {
              isAsync = true;
            }
          }

          // File upload check
          const reqBody = postOp.requestBody?.content || {};
          if (reqBody['multipart/form-data']) {
            const props = reqBody['multipart/form-data'].schema?.properties || {};
            if (props.file || props.metadata || props.ro_crate) {
              mode = 'metadata_file';
              uploadField = props.file ? 'file' : (props.metadata ? 'metadata' : 'file');
            }
          }
        }

        // === Build form HTML ===
        let formHtml = '';

        if (mode === 'metadata_file') {
          formHtml = `
            <p class="text-info mb-2">
              This test supports direct metadata upload.
              ${isAsync ? 'Results provided via polling/ticket.' : ''}
            </p>
            <form action="/champion/test-execution-proxy" method="post" enctype="multipart/form-data">
              <input type="hidden" name="endpoint" value="${endpoint}">
              <input type="hidden" name="submission_mode" value="metadata_file">
              <input type="hidden" name="test_identifier" value="${testId}">

              <label for="metadata_file_${testId}">Upload metadata (JSON/JSON-LD)</label>
              <input type="file" name="${uploadField}" id="metadata_file_${testId}" accept=".json,.jsonld" required>

              <small class="form-text text-muted">Typically ro-crate-metadata.json</small>

              <button type="submit" class="btn btn-primary mt-3">Submit Metadata</button>
            </form>

            ${isAsync ? '<p class="mt-3 small text-muted">After submission, poll the returned ticket URL for results.</p>' : ''}
          `;
        } else {
          formHtml = `
            <form action="/champion/test-execution-proxy" method="post">
              <input type="hidden" name="endpoint" value="${endpoint}">
              <input type="hidden" name="submission_mode" value="guid">

              <label for="resource_identifier_${testId}">Resource Identifier / GUID</label>
              <input type="text" name="resource_identifier" id="resource_identifier_${testId}"
                     placeholder="e.g. https://example.org/dataset" required>

              <button type="submit" class="btn btn-primary mt-3">Run Test</button>
            </form>
          `;
        }

        formContainer.innerHTML = formHtml;
        formContainer.style.display = 'block';

      } catch (err) {
        console.error('OpenAPI fetch/parse error:', err);
        errorEl.innerHTML = `Could not load API spec: ${err.message}. Using default GUID mode.`;
        errorEl.style.display = 'block';

        // Optional: still show fallback form
        formContainer.innerHTML = `<!-- fallback form here if you want -->`;
        formContainer.style.display = 'block';
      } finally {
        loadingEl.style.display = 'none';
      }
    });
  });
});
</script>


  <style>
  .submit-link {
    font-size: 0.9rem !important;
    padding: 6px 12px !important;
    line-height: 1.4 !important;
  }
  h2.submit-link {
    font-size: 1.2rem !important;
    margin: 0 !important;
  }
  </style>
  <div class="container" style="max-width: 80rem; width: 100%; margin-left: auto; margin-right: auto; padding: 20px;">
    <div class="header">
      <a href="/champion"><img src="/champion/champion_whitebgcrop.png" alt="FAIR Champion Logo"/></a>
      <h2><%= @tests.length %> Tests Available in the Registry</h2>
    </div>

    <header class="header">
        <div class="code-block">
          <p>Generic CURL command:</p>
          <pre>
  curl -H "Accept: application/json" https://tools.ostrails.eu/champion/tests
          </pre>
        </div>
    </header>
    <div class="code-block">
      <form action="/champion/tests/" method=GET>
        <p>Keyword Filter (one word, case-insensitive):<input type="text" name="keyword"/> </p>
        <input type="submit" value="filter by keyword"/>
      </form>
    </div>
    <%= yield %>
  </div>
</body>
</html>